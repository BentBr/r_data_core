# ─────────────────────────────────────────────────────────────
# RDataCore Docker Compose example — required configuration
# ─────────────────────────────────────────────────────────────
# Copy this file to `.env` and fill in real values:
#   cp env.example .env
# Never commit your real `.env`.

# ── Required secrets ────────────────────────────────────────
POSTGRES_PASSWORD=change-me-to-a-long-random-string
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
LICENSE_KEY=paste-your-license-jwt-here

# ── Optional: SMTP for system and workflow emails ───────────
# Format: smtp://host:port?tls=true&from=addr&from_name=Name
# Omit both to disable email features.
SYSTEM_SMTP_DSN=
WORKFLOW_SMTP_DSN=

# ── Optional: public-facing URLs ────────────────────────────
# Used in password-reset emails and OpenAPI examples.
FRONTEND_BASE_URL=http://localhost:8080
